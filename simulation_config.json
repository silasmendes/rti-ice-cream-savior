    {
      "regionAlias": "pqnacoes",
      "count": 2,
      "sellIntervalMin": 5,
      "sellIntervalMax": 10,
      "allowBulkPurchase": false,
      "doorOpenProbability": 0.03
    }
  ],

  "_comment_highSellers": "Simulate high-traffic freezers: higher depletion per cycle (depletionMin/Max) and boosted bulkPurchaseProbability. 'count' freezers are randomly picked from the given region at simulation start.",
  "highSellers": [
    {
      "regionAlias": "caissodre",
      "count": 1,
      "depletionMin": 0.8,
      "depletionMax": 1.5,
